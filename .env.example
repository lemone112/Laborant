# ═══════════════════════════════════════════════════════════════════════
# Laborant — AI Code Review Pipeline
# Copy this file to .env and fill in the values
# ═══════════════════════════════════════════════════════════════════════

# ── LLM (REQUIRED) ─────────────────────────────────────────────────────
# OpenAI-compatible API endpoint
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=sk-...

# Model aliases — zero hardcoding, swap freely
LLM_CHEAP_MODEL=gpt-4o-mini
LLM_BASE_MODEL=gpt-4o
LLM_FRONTIER_MODEL=o3
LLM_EMBEDDING_MODEL=text-embedding-3-small

# Token limits per tier (optional — defaults shown)
# LLM_CHEAP_MAX_TOKENS=2048
# LLM_BASE_MAX_TOKENS=4096
# LLM_FRONTIER_MAX_TOKENS=8192
# LLM_EMBEDDING_DIM=1536

# ── Pipeline Budget ─────────────────────────────────────────────────────
# Maximum LLM calls per review (fail-fast when exceeded)
# PIPELINE_MAX_LLM_CALLS=25
# Maximum estimated cost per review in USD
# PIPELINE_MAX_COST_USD=0.50

# CoVe verification for escalated findings
# PIPELINE_COVE_ENABLED=true
# Max escalated findings to verify per review
# PIPELINE_COVE_MAX_FINDINGS=5
# Enable/disable triple review (Logic + Risk + Consistency)
# PIPELINE_TRIPLE_REVIEW=true

# Model-to-tier mapping (JSON string, override if needed)
# PIPELINE_MODEL_MAP={"landscapeScan":"cheap","riskMap":"base","reviewLogic":"frontier","reviewRisk":"frontier","reviewConsistency":"base","consensus":"frontier","coveVerify":"base","report":"base"}

# ── GitLab (optional — needed for MR integration) ──────────────────────
# GITLAB_URL=https://gitlab.com
# GITLAB_TOKEN=
# GITLAB_WEBHOOK_SECRET=

# ── Temporal (optional — needed for durable workflow execution) ─────────
# TEMPORAL_URL=localhost:7233
# TEMPORAL_NAMESPACE=default

# ── Infrastructure (optional — pipeline degrades gracefully without) ────
# Neo4j — dependency graph for risk mapping
# NEO4J_URL=bolt://localhost:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=

# Qdrant — vector DB for semantic code search
# QDRANT_URL=http://localhost:6333

# PostgreSQL — feedback tracking (false positive learning)
# DATABASE_URL=postgresql://localhost:5432/laborant

# ── MCP Server ──────────────────────────────────────────────────────────
# MCP_PORT=3001
# MCP_TRANSPORT=stdio   # or 'sse' for HTTP-based transport

# ── API Server ──────────────────────────────────────────────────────────
# API_PORT=3000
# REVIEW_LANGUAGE=en   # or 'ru'
