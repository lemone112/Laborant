# ── LLM (REQUIRED) ─────────────────────────────────
LLM_BASE_URL=http://10.0.0.5:8080/v1
LLM_API_KEY=sk-your-api-key
LLM_CHEAP_MODEL=gpt-4o-mini
LLM_BASE_MODEL=gpt-4o
LLM_FRONTIER_MODEL=o3
LLM_EMBEDDING_MODEL=text-embedding-3-small
LLM_CHEAP_MAX_TOKENS=2048
LLM_BASE_MAX_TOKENS=4096
LLM_FRONTIER_MAX_TOKENS=8192
LLM_EMBEDDING_DIM=1536

# ── Pipeline ─────────────────────────────────────
PIPELINE_MAX_LLM_CALLS=25
PIPELINE_MAX_COST_USD=0.50
PIPELINE_COVE_ENABLED=true
PIPELINE_COVE_MAX_FINDINGS=5
PIPELINE_MODEL_MAP={"landscapeScan":"cheap","riskMap":"base","reviewLogic":"frontier","reviewRisk":"frontier","reviewConsistency":"base","consensus":"frontier","coveVerify":"base","report":"base"}

# ── Infrastructure (OPTIONAL — pipeline works without them) ──
NEO4J_URL=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme
QDRANT_URL=http://localhost:6333
DATABASE_URL=postgresql://temporal:temporal@localhost:5432/laborant

# ── GitLab (OPTIONAL — for webhook integration) ──
GITLAB_URL=https://gitlab.company.com
GITLAB_TOKEN=glpat-xxxxxxxxxxxx
GITLAB_WEBHOOK_SECRET=your-webhook-secret

# ── Temporal (OPTIONAL — for durable orchestration) ──
TEMPORAL_URL=localhost:7233
TEMPORAL_NAMESPACE=default

# ── API ──────────────────────────────────────────
API_PORT=3000
MCP_PORT=3001
MCP_TRANSPORT=stdio
REVIEW_LANGUAGE=ru
