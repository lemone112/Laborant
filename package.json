{
  "name": "ai-code-review",
  "version": "1.0.0",
  "description": "Production AI Code Review Pipeline — Temporal + LangGraph + tree-sitter + MCP",
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/main.js",
    "dev": "tsx watch src/main.ts",
    "worker": "tsx src/worker.ts",
    "mcp": "tsx src/mcp/server.ts",
    "reindex": "tsx src/repo-intelligence/reindex.workflow.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "docker:build": "docker build -t ai-code-review .",
    "docker:up": "docker compose -f docker/docker-compose.yml up -d",
    "docker:prod": "docker compose -f docker/docker-compose.prod.yml up -d"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@temporalio/activity": "^1.11.7",
    "@temporalio/client": "^1.11.7",
    "@temporalio/common": "^1.11.7",
    "@temporalio/worker": "^1.11.7",
    "@temporalio/workflow": "^1.11.7",
    "dotenv": "^16.4.7",
    "express": "^5.1.0",
    "neo4j-driver": "^5.28.1",
    "openai": "^4.95.1",
    "@qdrant/js-client-rest": "^1.13.0",
    "tree-sitter": "^0.21.1",
    "tree-sitter-typescript": "^0.21.2",
    "tree-sitter-python": "^0.21.0",
    "tree-sitter-go": "^0.21.2",
    "tree-sitter-rust": "^0.21.0",
    "zod": "^3.24.3",
    "zod-to-json-schema": "^3.24.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/express": "^5.0.2",
    "@types/node": "^22.15.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.3"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
